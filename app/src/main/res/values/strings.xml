    <!-- Tutorial step 2: Section header -->
    <string name="tutorial_section_title">Tap a Category</string>
    <string name="tutorial_section_body">Tap any category to add items to it.</string>

    <!-- Tutorial step 3: Item row -->
    <string name="tutorial_item_title">Add &amp; Remove Items</string>
    <string name="tutorial_item_body">Tap an item to add 1.\nLong press an item for options (Edit, Move, Delete).\nLong press the quantity badge to subtract.</string>

    <!-- Tutorial step 4: Hold section header -->
    <string name="tutorial_hold_section_title">Rearrange Categories</string>
    <string name="tutorial_hold_section_body">Hold a category to drag it into a new order, or drop it on the delete zone.</string>

